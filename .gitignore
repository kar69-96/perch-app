# macOS
.DS_Store

# Xcode / build products
*.xcuserstate
xcuserdata/
notch/build/
build/
DerivedData/

# Packaging artifacts
dist/
releases/
*.zip

# Perch on-disk state — all runtime state lives in the repo (resolved by
# PerchSupportPaths). Ignore the folders' contents; never commit them.
support/
logs/

# Secrets & signing material — NEVER tracked. Real values are injected at
# package time (see scripts/package-release.sh); the committed Info.plist
# carries only placeholders.
.env
.env.*
*.keychain-db
*_ed25519_key
*_ed25519_key.pub
*.pem
*.p12
*.p8
*.mobileprovision
*.provisionprofile
id_rsa*
*.secret
